      "parameters": {
        "jsCode": "\nconst data = $input.first().json;\n\nconst isHighPriority = data.priority === 'high';\n\nreturn [{\n  json: {\n    ...data,\n    statusLabel: isHighPriority \n      ? 'Lead prioritaire détecté' \n      : 'Lead standard détecté',\n    statusColor: isHighPriority ? '#e74c3c' : '#2ecc71',\n    statusEmoji: isHighPriority ? '⚡' : '✅',\n    badgeColor: isHighPriority ? '#e74c3c' : '#2ecc71',\n  }\n}];"
