      "name": "Webhook Lead Intake",
      "webhookId": "53624a18-67d2-4c8f-b91b-6c3d440c7896"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst errors = [];\n\nif (!body.firstName || body.firstName.trim() === '') {\n  errors.push({ field: 'firstName', reason: 'Le prénom est requis.' });\n}\n\nconst emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nif (!body.email || body.email.trim() === '') {\n  errors.push({ field: 'email', reason: \"L'email est requis.\" });\n} else if (!emailRegex.test(body.email)) {\n  errors.push({ field: 'email', reason: \"L'email n'est pas valide.\" });\n}\n\nif (!body.projectType || body.projectType.trim() === '') {\n  errors.push({ field: 'projectType', reason: 'Le type de projet est requis.' });\n}\n\nif (!body.city || body.city.trim() === '') {\n  errors.push({ field: 'city', reason: 'La ville est requise.' });\n}\n\nif (errors.length > 0) {\n  return [{\n    json: {\n      ...body,\n      valid: false,\n      error: 'VALIDATION_ERROR',\n      message: `${errors.length} champ(s) invalide(s).`,\n      errors\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    ...body,\n    valid: true\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -976,
        96
      ],
      "id": "18d3055a-3a52-4ac5-801c-acfdb0e202e0",
      "name": "Handle Missing Fieldscript"
    },
    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\n\nconst body = $input.first().json;\n\nconst now = new Date();\n\nconst priority =\n  body.projectType === 'seller' ||\n  body.budget > 400000\n    ? 'high'\n    : 'standard';\n\nconst leadId = crypto.randomUUID();\n\nconst summary =\n`${body.firstName} ${body.lastName}\nest un lead ${\nbody.projectType === 'seller'\n? 'vendeur'\n: 'acheteur'\n} à ${body.city}\navec un budget de ${body.budget} €.`;\n\nreturn [{\n  json: {\n    ...body,\n    leadId,\n    receivedAt: now.toISOString(),\n    priority,\n    summary\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -592,
        80
      ],
      "id": "0a23154a-5d70-4183-bf1c-d010eb9911aa",
      "name": "Enrich Lead Data"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{\n  {\n    success: true,\n    leadId: $('Enrich Lead Data').item.json.leadId,\n    priority: $('Enrich Lead Data').item.json.priority,\n    summary: $('Enrich Lead Data').item.json.summary,\n    message: \"Merci pour votre demande. Votre demande a bien été prise en compte. Notre équipe vous contactera dans les meilleurs délais.\"\n  }\n}}",
        "options": {}
