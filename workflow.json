    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\nconst requiredFields = ['firstName', 'email', 'projectType', 'city'];\nconst missingFields = requiredFields.filter((field) => !body[field]);\n\nreturn [\n  {\n    json: {\n      success: false,\n      error: 'MISSING_REQUIRED_FIELDS',\n      message: 'Certains champs obligatoires sont manquants. Veuillez vérifier votre demande.',\n      missingFields,\n    },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        192
      ],
      "id": "b9839b13-c477-4632-8401-9c13bff6e6a5",
      "name": "Handle Missing Fieldscript"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\nconst now = new Date();\n\nconst priority = (body.projectType === 'seller' || body.budget > 400000) ? 'high' : 'normal';\n\nconst leadId = `lead_${now.toISOString().slice(0,10).replace(/-/g, '')}_${Math.random().toString(36).slice(2, 8)}`;\n\nconst summary = `${body.firstName} ${body.lastName} est un lead ${body.projectType === 'seller' ? 'vendeur' : 'acheteur'} à ${body.city} avec un budget de ${body.budget} €.`;\n\nreturn [{\n  json: {\n    ...body,\n    leadId,\n    receivedAt: now.toISOString(),\n    priority,\n    summary\n  }\n}];"
      },
